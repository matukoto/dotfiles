{
  "mcpServers": {
    "playwright": {
      "type": "local",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ],
      "tools": [
        "*"
      ],
      "env": {},
      "source": "user"
    },
    "svelte": {
      "type": "http",
