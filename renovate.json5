{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "github>aquaproj/aqua-renovate-config#2.10.0"
  ],
  "timezone": "Asia/Tokyo",
  "prConcurrentLimit": 1,
  "prHourlyLimit": 0,
  "automerge": true,
  "dependencyDashboard": true,
  "platformAutomerge": true,
  "packageRules": [
    {
      "matchUpdateTypes": [
        "patch"
      ],
      "minimumReleaseAge": "1 days",
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "minor"
      ],
      "minimumReleaseAge": "1 days",
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "matchPackageNames": [
        "aquaproj/aqua-registry"
      ],
      "extends": [
        "schedule:earlyMondays"
      ]
    },
    {
      "matchFileNames": [
        "dot_config/mise/**",
        "**/mise.toml"
      ],
      "groupName": "mise",
      "commitMessageTopic": "mise"
    },
    {
      "matchFileNames": [
        "dot_config/aqua/**"
      ],
      "excludePackageNames": [
        "aquaproj/aqua-registry"
      ],
      "groupName": "aqua",
      "commitMessageTopic": "aqua"
    },
    {
      "matchManagers": [
        "mise"
      ],
      "matchPackageNames": [
        "java"
      ],
      "description": "Restrict Java versions to mise-compatible format",
      "allowedVersions": "/^corretto-\\d+\\.\\d+\\.\\d+\\.\\d+\\.\\d+$/",
      "versioning": "loose"
    }
  ]
}
